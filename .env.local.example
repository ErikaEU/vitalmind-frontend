# URL del backend FastAPI, usada desde el servidor (Server Components, Route
# Handlers, Server Actions) y por el proxy same-origin app/api/backend/[...path].
# Backend real desplegado en Render (plan free — puede tener cold start de 30-50s).
API_URL=https://vitalmind-backend-4vda.onrender.com

# URL del backend accesible desde el navegador — usada solo por el portal público del alumno
# (app/(public)/cuestionario), que llama directo a FastAPI sin pasar por el proxy admin.
NEXT_PUBLIC_API_URL=https://vitalmind-backend-4vda.onrender.com

# Debe ser EXACTAMENTE el mismo valor que SECRET_KEY configurado en el backend
# desplegado (variable de entorno en Render, no en un .env local). El proxy
# (proxy.ts) y las Server Actions de login/lib/auth.ts verifican la firma del
# JWT con esta clave para poder proteger las rutas (admin) sin volver a golpear
# al backend en cada navegación.
JWT_SECRET_KEY=cambia_esto_por_el_SECRET_KEY_real_del_backend_en_render
JWT_ALGORITHM=HS256

# Nombre de la cookie httpOnly donde se guarda el JWT de la psicóloga/administrador.
AUTH_COOKIE_NAME=vitalmind_token
